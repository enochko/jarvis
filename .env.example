# Jarvis Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# --- Phase 1: Telegram ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
ALLOWED_USERS=123456789  # comma-separated Telegram user IDs

# --- Phase 3: Google Services ---
# Store OAuth credentials outside the vault and outside this repo.
# Reference the path here if needed by your agent engine.
# GOOGLE_CREDENTIALS_PATH=/path/outside/vault/google-credentials.json

# --- Optional: API keys for providers ---
# Not needed if using Claude Code via subscription (recommended).
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
